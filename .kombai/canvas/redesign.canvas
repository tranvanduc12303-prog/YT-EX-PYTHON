      </div>\n            <div class=\"p-6 border border-[#2F4F4F] bg-[#010B13] relative overflow-hidden group\" data-kid=\"58\">\n              <p class=\"text-[10px] font-bold text-[#2F4F4F] uppercase tracking-[0.2em] mb-4\" data-kid=\"59\">Success_Downloads</p>\n              <h3 class=\"font-['Space_Grotesk'] text-5xl font-bold text-[#15F4EE]\" data-kid=\"60\">856</h3>\n              <div class=\"mt-4 flex items-center gap-2 text-[10px] text-[#2F4F4F] font-bold\" data-kid=\"61\">\n                <span data-kid=\"62\">Total Payload: 4.2GB</span>\n              </div>\n            </div>\n            <div class=\"p-6 border border-[#2F4F4F] bg-[#010B13] relative overflow-hidden group\" data-kid=\"63\">\n              <p class=\"text-[10px] font-bold text-[#2F4F4F] uppercase tracking-[0.2em] mb-4\" data-kid=\"64\">Automation_Uptime</p>\n              <h3 class=\"font-['Space_Grotesk'] text-5xl font-bold text-[#15F4EE]\" data-kid=\"65\">09<span class=\"text-2xl opacity-50\" data-kid=\"66\">d</span>:14<span class=\"text-2xl opacity-50\" data-kid=\"67\">h</span></h3>\n              <div class=\"mt-4 flex items-center gap-2 text-[10px] text-[#15F4EE] font-bold\" data-kid=\"68\">\n                <span class=\"animate-pulse\" data-kid=\"69\">● System.Active</span>\n              </div>\n            </div>\n          </div>\n\n          \n          <div class=\"col-span-8 border border-[#2F4F4F] p-8 bg-[#010B13]\" data-kid=\"70\">\n             <div class=\"flex items-center justify-between mb-8\" data-kid=\"71\">\n               <h4 class=\"font-['Space_Grotesk'] text-lg font-bold uppercase tracking-widest text-[#15F4EE]\" data-kid=\"72\">Network.Throughput_Dynamics</h4>\n               <div class=\"flex gap-4\" data-kid=\"73\">\n                 <button class=\"px-4 py-1 text-[10px] font-bold border border-[#15F4EE] text-[#15F4EE] uppercase\" data-kid=\"74\">Real_Time</button>\n                 <button class=\"px-4 py-1 text-[10px] font-bold border border-[#2F4F4F] text-[#2F4F4F] uppercase hover:text-[#15F4EE] hover:border-[#15F4EE] transition-all\" data-kid=\"75\">Historical</button>\n               </div>\n             </div>\n             <div class=\"h-[300px]\" data-kid=\"76\">\n               <canvas id=\"dashboardChart\" data-kid=\"77\"></canvas>\n             </div>\n          </div>\n\n          \n          <div class=\"col-span-4 border border-[#2F4F4F] p-8 bg-[#010B13] flex flex-col\" data-kid=\"78\">\n            <h4 class=\"font-['Space_Grotesk'] text-lg font-bold uppercase tracking-widest text-[#15F4EE] mb-8\" data-kid=\"79\">System_Audit_Log</h4>\n            <div class=\"flex-1 space-y-6 overflow-y-auto custom-scrollbar pr-2\" data-kid=\"80\">\n              <div class=\"flex items-start gap-4 p-4 border border-[#2F4F4F]/30 hover:border-[#15F4EE]/30 transition-colors\" data-kid=\"81\">\n                <div class=\"w-2 h-2 rounded-full bg-[#15F4EE] mt-1\" data-kid=\"82\"></div>\n                <div data-kid=\"83\">\n                  <p class=\"text-[11px] font-bold text-[#f8fafc] mb-1\" data-kid=\"84\">DOWNLOAD_COMPLETE</p>\n                  <p class=\"text-[10px] text-[#2F4F4F] uppercase\" data-kid=\"85\">Video_ID: yt_88291_x</p>\n                  <p class=\"text-[10px] text-[#94a3b8] mt-1 font-medium\" data-kid=\"86\">14:22:01 // Client.01</p>\n                </div>\n              </div>\n              <div class=\"flex items-start gap-4 p-4 border border-[#2F4F4F]/30\" data-kid=\"87\">\n                <div class=\"w-2 h-2 rounded-full bg-[#ef4444] mt-1\" data-kid=\"88\"></div>\n                <div data-kid=\"89\">\n                  <p class=\"text-[11px] font-bold text-[#f8fafc] mb-1\" data-kid=\"90\">AUTH_FAILURE</p>\n                  <p class=\"text-[10px] text-[#2F4F4F] uppercase\" data-kid=\"91\">Gmail_Creator: Step_03_Proxy</p>\n                  <p class=\"text-[10px] text-[#94a3b8] mt-1 font-medium\" data-kid=\"92\">14:18:45 // Hidemium.Main</p>\n                </div>\n              </div>\n              <div class=\"flex items-start gap-4 p-4 border border-[#2F4F4F]/30\" data-kid=\"93\">\n                <div class=\"w-2 h-2 rounded-full bg-[#15F4EE] mt-1\" data-kid=\"94\"></div>\n                <div data-kid=\"95\">\n                  <p class=\"text-[11px] font-bold text-[#f8fafc] mb-1\" data-kid=\"96\">EXCEL_PARSE_INIT</p>\n                  <p class=\"text-[10px] text-[#2F4F4F] uppercase\" data-kid=\"97\">Source: Data_v2.xlsx</p>\n                  <p class=\"text-[10px] text-[#94a3b8] mt-1 font-medium\" data-kid=\"98\">14:05:12 // System.Root</p>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n      </section>\n\n      \n      <section id=\"view-downloader\" class=\"view space-y-10\" data-kid=\"99\">\n        <div class=\"grid grid-cols-12 gap-10 h-[calc(100vh-220px)]\" data-kid=\"100\">\n          \n          <div class=\"col-span-4 h-full flex flex-col gap-6\" data-kid=\"101\">\n            <div class=\"flex-1 dashed-box flex flex-col items-center justify-center p-12 text-center group cursor-pointer hover:bg-[#15F4EE]/5 transition-all\" data-kid=\"102\">\n              <div class=\"w-20 h-20 mb-8 border border-[#2F4F4F] flex items-center justify-center rounded-2xl group-hover:border-[#15F4EE] transition-colors\" data-kid=\"103\">\n                <i class=\"ti ti-cloud-upload text-4xl text-[#2F4F4F] group-hover:text-[#15F4EE] transition-colors\" data-kid=\"104\"></i>\n              </div>\n              <h3 class=\"font-['Space_Grotesk'] text-xl font-bold uppercase tracking-widest mb-4\" data-kid=\"105\">Initialize_Data_Ingest</h3>\n              <p class=\"text-xs text-[#94a3b8] leading-relaxed max-w-[200px] mb-8\" data-kid=\"106\">Drop your (.xlsx, .xlsm) binary here to begin extraction.</p>\n              <button class=\"px-8 py-3 bg-transparent border border-[#15F4EE] text-[#15F4EE] text-[10px] font-bold uppercase tracking-[0.2em] hover:bg-[#15F4EE] hover:text-[#010B13] transition-all\" data-kid=\"107\">Open_File_Sys</button>\n            </div>\n            \n            <div class=\"p-6 border border-[#2F4F4F] bg-[#010B13]/50\" data-kid=\"108\">\n              <h5 class=\"text-[10px] font-bold text-[#2F4F4F] uppercase mb-4 tracking-widest\" data-kid=\"109\">Parser.Config</h5>\n              <div class=\"space-y-4\" data-kid=\"110\">\n                <label class=\"flex items-center gap-3 cursor-pointer group\" data-kid=\"111\">\n                  <div class=\"w-4 h-4 border border-[#2F4F4F] flex items-center justify-center group-hover:border-[#15F4EE]\" data-kid=\"112\">\n                    <div class=\"w-2 h-2 bg-[#15F4EE]\" data-kid=\"113\"></div>\n                  </div>\n                  <span class=\"text-[11px] text-[#94a3b8] uppercase\" data-kid=\"114\">Auto_Detect_YT_Links</span>\n                </label>\n                <label class=\"flex items-center gap-3 cursor-pointer group\" data-kid=\"115\">\n                  <div class=\"w-4 h-4 border border-[#2F4F4F] flex items-center justify-center group-hover:border-[#15F4EE]\" data-kid=\"116\"></div>\n                  <span class=\"text-[11px] text-[#2F4F4F] uppercase\" data-kid=\"117\">High_Efficiency_Mode</span>\n                </label>\n              </div>\n            </div>\n          </div>\n\n          \n          <div class=\"col-span-8 flex flex-col border border-[#2F4F4F] bg-[#010B13] overflow-hidden\" data-kid=\"118\">\n            <div class=\"p-6 border-b border-[#2F4F4F] flex items-center justify-between\" data-kid=\"119\">\n              <div class=\"flex items-center gap-4\" data-kid=\"120\">\n                <h4 class=\"font-['Space_Grotesk'] text-sm font-bold uppercase tracking-widest text-[#15F4EE]\" data-kid=\"121\">Output_Channel_Array</h4>\n                <span class=\"text-[10px] px-2 py-0.5 border border-[#2F4F4F] text-[#94a3b8]\" data-kid=\"122\">Rows: 124</span>\n              </div>\n              <button onclick=\"simulateTableReveal()\" class=\"text-[10px] font-bold text-[#15F4EE] uppercase underline underline-offset-4 decoration-[#15F4EE]/30 hover:decoration-[#15F4EE]\" data-kid=\"123\">Refresh_View</button>\n            </div>\n            <div class=\"flex-1 overflow-auto custom-scrollbar\" data-kid=\"124\">\n              <table class=\"w-full text-left border-collapse\" data-kid=\"125\">\n                <thead class=\"sticky top-0 bg-[#010B13] z-10\" data-kid=\"126\">\n                  <tr class=\"text-[10px] font-bold text-[#2F4F4F] uppercase tracking-widest border-b border-[#2F4F4F]\" data-kid=\"127\">\n                    <th class=\"p-4 border-r border-[#2F4F4F] w-12 text-center\" data-kid=\"128\">ID</th>\n                    <th class=\"p-4 border-r border-[#2F4F4F]\" data-kid=\"129\">Channel_Entity</th>\n                    <th class=\"p-4 border-r border-[#2F4F4F]\" data-kid=\"130\">Platform_ID</th>\n                    <th class=\"p-4 text-center\" data-kid=\"131\">Protocol_Action</th>\n                  </tr>\n                </thead>\n                <tbody id=\"downloader-table-body\" data-kid=\"132\">\n                  \n                </tbody>\n              </table>\n            </div>\n          </div>\n        </div>\n      </section>\n\n      \n      <section id=\"view-automation\" class=\"view space-y-10\" data-kid=\"133\">\n        <div class=\"grid grid-cols-12 gap-10\" data-kid=\"134\">\n          \n          <div class=\"col-span-4 space-y-8\" data-kid=\"135\">\n            <div class=\"p-8 border border-[#2F4F4F] bg-[#010B13]\" data-kid=\"136\">\n              <h4 class=\"font-['Space_Grotesk'] text-lg font-bold uppercase tracking-widest text-[#15F4EE] mb-8\" data-kid=\"137\">Process_Parameters</h4>\n              <div class=\"space-y-6\" data-kid=\"138\">\n                <div data-kid=\"139\">\n                  <label class=\"text-[10px] font-bold text-[#2F4F4F] uppercase block mb-3\" data-kid=\"140\">Origin_Column_Map</label>\n                  <input type=\"number\" value=\"1\" class=\"w-full bg-transparent border border-[#2F4F4F] px-4 py-3 text-sm focus:border-[#15F4EE] outline-none transition-colors text-[#15F4EE]\" data-kid=\"141\">\n                </div>\n                <div data-kid=\"142\">\n                  <label class=\"text-[10px] font-bold text-[#2F4F4F] uppercase block mb-3\" data-kid=\"143\">Target_Output_Map</label>\n                  <input type=\"number\" value=\"2\" class=\"w-full bg-transparent border border-[#2F4F4F] px-4 py-3 text-sm focus:border-[#15F4EE] outline-none transition-colors text-[#15F4EE]\" data-kid=\"144\">\n                </div>\n                <div class=\"pt-4\" data-kid=\"145\">\n                  <button onclick=\"simulateAutomation()\" class=\"w-full py-4 bg-[#15F4EE] text-[#010B13] font-black uppercase tracking-[0.4em] text-xs hover:bg-white transition-all shadow-[0_0_20px_rgba(21,244,238,0.3)]\" data-kid=\"146\">Execute_Engine</button>\n                </div>\n              </div>\n            </div>\n            \n            <div class=\"p-8 border border-[#2F4F4F] bg-[#010B13]\" data-kid=\"147\">\n              <h5 class=\"text-[10px] font-bold text-[#2F4F4F] uppercase mb-4\" data-kid=\"148\">Automation_Metadata</h5>\n              <div class=\"grid grid-cols-2 gap-4\" data-kid=\"149\">\n                <div class=\"text-[10px] text-[#94a3b8]\" data-kid=\"150\">Engine: <span class=\"text-[#15F4EE]\" data-kid=\"151\">Hidemium_v2</span></div>\n                <div class=\"text-[10px] text-[#94a3b8]\" data-kid=\"152\">Proxy: <span class=\"text-[#15F4EE]\" data-kid=\"153\">Enabled</span></div>\n                <div class=\"text-[10px] text-[#94a3b8]\" data-kid=\"154\">Retry_Limit: <span class=\"text-[#15F4EE]\" data-kid=\"155\">03</span></div>\n                <div class=\"text-[10px] text-[#94a3b8]\" data-kid=\"156\">Thread_Count: <span class=\"text-[#15F4EE]\" data-kid=\"157\">08</span></div>\n              </div>\n            </div>\n          </div>\n\n          \n          <div class=\"col-span-8 flex flex-col h-[calc(100vh-220px)] border border-[#2F4F4F] bg-[#010B13] relative overflow-hidden\" data-kid=\"158\">\n            <div class=\"absolute inset-0 pointer-events-none bg-[radial-gradient(circle_at_center,transparent_0%,rgba(1,11,19,0.8)_100%)] z-10\" data-kid=\"159\"></div>\n            <div class=\"p-4 border-b border-[#2F4F4F] bg-[#010B13] flex items-center justify-between z-20\" data-kid=\"160\">\n              <div class=\"flex gap-1.5\" data-kid=\"161\">\n                <div class=\"w-2.5 h-2.5 rounded-full bg-[#2F4F4F]\" data-kid=\"162\"></div>\n                <div class=\"w-2.5 h-2.5 rounded-full bg-[#2F4F4F]\" data-kid=\"163\"></div>\n                <div class=\"w-2.5 h-2.5 rounded-full bg-[#2F4F4F]\" data-kid=\"164\"></div>\n              </div>\n              <span class=\"text-[10px] font-bold text-[#2F4F4F] uppercase tracking-widest\" data-kid=\"165\">Shell.Output_Streaming</span>\n              <div class=\"w-10\" data-kid=\"166\"></div>\n            </div>\n            <div id=\"terminal-content\" class=\"flex-1 p-6 font-['IBM_Plex_Mono'] text-[11px] text-[#15F4EE]/80 overflow-y-auto custom-scrollbar z-0\" data-kid=\"167\">\n               <div class=\"mb-2\" data-kid=\"168\">Excel.Automation.System.Ready [2026.06.17]</div>\n               <div class=\"mb-2\" data-kid=\"169\">User authenticated as Root_Admin...</div>\n               <div class=\"mb-2\" data-kid=\"170\">Waiting for execution command_</div>\n               <div id=\"live-logs\" class=\"space-y-1\" data-kid=\"171\"></div>\n            </div>\n          </div>\n        </div>\n      </section>\n\n    </main>\n  </div>\n</div>\n\n<script data-kid=\"172\">\n  gsap.registerPlugin(TextPlugin);\n\n  // Initialize Data\n  const channels = [\n    { name: \"Tech_Hacker_VN\", id: \"@tech_vn\", status: \"VALID\" },\n    { name: \"Automation_Pro_Max\", id: \"@auto_pro\", status: \"VALID\" },\n    { name: \"Data_Flow_Systems\", id: \"@df_sys\", status: \"ERROR\" },\n    { name: \"Cyber_Security_Lab\", id: \"@cs_lab\", status: \"VALID\" },\n    { name: \"Logic_Builder_TV\", id: \"@logic_tv\", status: \"VALID\" },\n    { name: \"Dev_Ops_Insider\", id: \"@devops_in\", status: \"VALID\" }\n  ];\n\n  // Populate Table\n  const tableBody = document.getElementById('downloader-table-body');\n  channels.forEach((c, i) => {\n    const row = document.createElement('tr');\n    row.className = 'table-row text-[11px] border-b border-[#2F4F4F]/30 hover:bg-[#15F4EE]/5 transition-colors group';\n    row.innerHTML = `\n      <td class=\"p-4 border-r border-[#2F4F4F]/30 text-center text-[#2F4F4F] group-hover:text-[#15F4EE]\">${(i+1).toString().padStart(2, '0')}</td>\n      <td class=\"p-4 border-r border-[#2F4F4F]/30 font-bold text-[#f8fafc] group-hover:text-[#15F4EE]\">${c.name}</td>\n      <td class=\"p-4 border-r border-[#2F4F4F]/30 text-[#94a3b8] uppercase\">${c.id}</td>\n      <td class=\"p-4 text-center\">\n        <button class=\"px-4 py-1 text-[9px] font-bold border ${c.status === 'VALID' ? 'border-[#15F4EE] text-[#15F4EE]' : 'border-[#ef4444] text-[#ef4444]'} uppercase tracking-widest hover:bg-current hover:text-[#010B13] transition-all\">\n          ${c.status === 'VALID' ? 'Fetch_Data' : 'Re_Scan'}\n        </button>\n      </td>\n    `;\n    tableBody.appendChild(row);\n  });\n\n  // View Management\n  function switchView(viewId, btn) {\n    // Nav UI\n    document.querySelectorAll('.nav-btn').forEach(b => {\n      b.querySelector('i').style.color = '#2F4F4F';\n      b.querySelector('.active-line').style.opacity = '0';\n    });\n    btn.querySelector('i').style.color = '#15F4EE';\n    btn.querySelector('.active-line').style.opacity = '1';\n\n    // View UI\n    document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));\n    const target = document.getElementById(`view-${viewId}`);\n    target.classList.add('active');\n    \n    // Breadcrumb Update\n    document.getElementById('breadcrumb-current').textContent = viewId.charAt(0).toUpperCase() + viewId.slice(1) + '_Main';\n\n    // Animations\n    if(viewId === 'downloader') simulateTableReveal();\n  }\n\n  // Animation: #gsap-scroll-batch (Table Reveal)\n  function simulateTableReveal() {\n    gsap.fromTo('.table-row', \n      { opacity: 0, y: 15 },\n      { opacity: 1, y: 0, stagger: 0.05, duration: 0.4, ease: \"power2.out\", overwrite: true }\n    );\n  }\n\n  // Animation: #gsap-text-plugin (Automation Logs)\n  function simulateAutomation() {\n    const logs = [\n      \"Starting Hidemium.Session_821...\",\n      \"Resolving Proxy.IP (Proxy-Secure-12)...\",\n      \"Authentication Success (Session_ID: CX_992).\",\n      \"Navigating to Target_URL_Array...\",\n      \"Parsing DOM_Structure... 45 items detected.\",\n      \"Extracting_Data: Row_001 Success.\",\n      \"Extracting_Data: Row_002 Success.\",\n      \"Buffer filled. Flushing to Data_Cache...\",\n      \"Process_Complete. Output: success_log.json\"\n    ];\n    \n    const container = document.getElementById('live-logs');\n    container.innerHTML = '';\n    \n    logs.forEach((log, index) => {\n      setTimeout(() => {\n        const div = document.createElement('div');\n        div.className = 'flex items-center gap-2';\n        div.innerHTML = `<span class=\"text-[#2F4F4F]\">></span><span id=\"log-${index}\"></span>`;\n        container.appendChild(div);\n        \n        gsap.to(`#log-${index}`, {\n          text: log,\n          duration: log.length * 0.02,\n          ease: \"none\"\n        });\n      }, index * 800);\n    });\n  }\n\n  // Dashboard Chart\n  const ctx = document.getElementById('dashboardChart').getContext('2d');\n  new Chart(ctx, {\n    type: 'line',\n    data: {\n      labels: ['00:00', '04:00', '08:00', '12:00', '16:00', '20:00', '23:59'],\n      datasets: [{\n        label: 'Payload',\n        data: [12, 19, 3, 5, 32, 23, 18],\n        borderColor: '#15F4EE',\n        backgroundColor: 'rgba(21, 244, 238, 0.05)',\n        borderWidth: 2,\n        tension: 0.4,\n        fill: true,\n        pointRadius: 4,\n        pointBackgroundColor: '#15F4EE'\n      }]\n    },\n    options: {\n      responsive: true,\n      maintainAspectRatio: false,\n      plugins: { legend: { display: false } },\n      scales: {\n        x: { grid: { color: 'rgba(47, 79, 79, 0.2)' }, ticks: { color: '#2F4F4F', font: { size: 10 } } },\n        y: { grid: { color: 'rgba(47, 79, 79, 0.2)' }, ticks: { color: '#2F4F4F', font: { size: 10 } } }\n      }\n    }\n  });\n\n  // Ambient Loop: Status Pulse\n  gsap.to('.status-pulse', {\n    boxShadow: '0 0 15px #15F4EE',\n    duration: 1.5,\n    repeat: -1,\n    yoyo: true,\n    ease: \"power1.inOut\"\n  });\n</script>",
