      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;600;700&family=IBM+Plex+Mono:wght@400;500;600&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    --color-bg: #010B13;\n    --color-panel: #010B13;\n    --color-border: #2F4F4F;\n    --color-accent: #15F4EE;\n    --color-text: #f8fafc;\n    --color-muted: #94a3b8;\n  }\n\n  body {\n    margin: 0;\n    padding: 0;\n    background-color: var(--color-bg);\n    color: var(--color-text);\n    font-family: 'IBM Plex Mono', monospace;\n    overflow: hidden;\n  }\n\n  /* Pattern: #terminal-cli Custom Scrollbar */\n  .custom-scrollbar::-webkit-scrollbar { width: 4px; }\n  .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }\n  .custom-scrollbar::-webkit-scrollbar-thumb { background: var(--color-border); border-radius: 2px; }\n\n  /* Pattern: #dashed */\n  .dashed-box {\n    border: 1px dashed var(--color-border);\n    background: rgba(47, 79, 79, 0.05);\n  }\n\n  /* View Transition */\n  .view { display: none; }\n  .view.active { display: block; animation: view-enter 0.4s cubic-bezier(0.16, 1, 0.3, 1); }\n  @keyframes view-enter {\n    from { opacity: 0; transform: translateY(10px); }\n    to { opacity: 1; transform: translateY(0); }\n  }\n\n  /* GSAP Specific Styling */\n  .table-row { opacity: 0; transform: translateY(10px); }\n  \n  /* Status Pulse */\n  .status-pulse {\n    width: 8px; height: 8px; border-radius: 50%; background: var(--color-accent);\n    box-shadow: 0 0 8px var(--color-accent);\n  }\n</style>\n\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"1\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/TextPlugin.min.js\" data-kid=\"2\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/chart.js\" data-kid=\"3\"></script>\n\n<div class=\"flex h-screen w-full bg-[#010B13] selection:bg-[#15F4EE]/30 sel