      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700&family=DM+Sans:wght@400;500&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  @layer base {\n    body {\n      @apply font-['DM_Sans'] text-white bg-[#1E2952] overflow-x-hidden;\n    }\n    h1, h2, h3, h4 {\n      @apply font-['Outfit'] font-bold;\n    }\n  }\n\n  .glass-card {\n    @apply bg-white/10 backdrop-blur-xl border border-white/20 rounded-3xl shadow-[0_8px_32px_0_rgba(0,0,0,0.37)];\n  }\n\n  .mesh-gradient {\n    background: radial-gradient(at 0% 0%, #1E2952 0%, transparent 50%),\n                radial-gradient(at 100% 0%, #301934 0%, transparent 50%),\n                radial-gradient(at 100% 100%, #1E2952 0%, transparent 50%),\n                radial-gradient(at 0% 100%, #301934 0%, transparent 50%);\n  }\n\n  .orb {\n    @apply absolute rounded-full blur-[120px] opacity-40 mix-blend-screen animate-pulse;\n  }\n\n  .pill-nav-item {\n    @apply flex items-center gap-2 px-4 py-2 rounded-full transition-all duration-300 text-white/60 hover:text-white hover:bg-white/10;\n  }\n  .pill-nav-item.active {\n    @apply bg-[#00FFBF] text-[#1E2952] font-semibold;\n  }\n\n  .pinterest-grid {\n    display: grid;\n    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));\n    grid-auto-rows: 20px;\n  }\n\n  .progress-ring-bg { stroke: rgba(255,255,255,0.1); }\n  .progress-ring-fill { stroke: #00FFBF; stroke-linecap: round; transform: rotate(-90deg); transform-origin: 50% 50%; }\n\n  ::-webkit-scrollbar { width: 8px; }\n  ::-webkit-scrollbar-track { background: transparent; }\n  ::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 10px; }\n  ::-webkit-scrollbar-thumb:hover { background: rgba(255,255,255,0.2); }\n</style>\n\n<div class=\"relative min-h-screen mesh-gradient overflow-hidden\" data-kid=\"1\">\n  \n  <div class=\"orb bg-cyan-500 w-[400px] h-[400px] -top-20 -left-20\" data-kid=\"2\"></div>\n  <div class=\"orb bg-purple-600 w-[500px] h-[500px] top-1/2 -right-20\" data-kid=\"3\"></div>\n  <div class=\"orb bg-blue-700 w-[300px] h-[300px] bottom-0 left-1/3\" data-kid=\"4\"></div>\n\n  \n  <header class=\"fixed top-6 left-1/2 -translate-x-1/2 z-50\" data-kid=\"5\">\n    <nav class=\"flex items-center gap-1 p-2 bg-white/5 backdrop-blur-2xl border border-white/10 rounded-full shadow-2xl\" data-kid=\"6\">\n      <div class=\"px-4 py-1 mr-2 border-r border-white/10 flex items-center gap-2\" data-kid=\"7\">\n        <div class=\"w-8 h-8 bg-[#00FFBF] rounded-lg flex items-center justify-center shadow-[0_0_20px_rgba(0,255,191,0.4)]\" data-kid=\"8\">\n          <i class=\"ti ti-file-spreadsheet text-[#1E2952] text-xl\" data-kid=\"9\"></i>\n        </div>\n        <span class=\"font-bold text-sm tracking-tight hidden md:block\" data-kid=\"10\">EXCEL PRO</span>\n      </div>\n      <button class=\"pill-nav-item active\" data-view=\"dashboard\" data-kid=\"11\">\n        <i class=\"ti ti-chart-pie text-lg\" data-kid=\"12\"></i><span class=\"text-sm\" data-kid=\"13\">Stats</span>\n      </button>\n      <button class=\"pill-nav-item\" data-view=\"downloader\" data-kid=\"14\">\n        <i class=\"ti ti-cloud-download text-lg\" data-kid=\"15\"></i><span class=\"text-sm\" data-kid=\"16\">Downloader</span>\n      </button>\n      <button class=\"pill-nav-item\" data-view=\"automation\" data-kid=\"17\">\n        <i class=\"ti ti-terminal text-lg\" data-kid=\"18\"></i><span class=\"text-sm\" data-kid=\"19\">Automation</span>\n      </button>\n      <button class=\"pill-nav-item\" data-view=\"email\" data-kid=\"20\">\n        <i class=\"ti ti-mail text-lg\" data-kid=\"21\"></i><span class=\"text-sm\" data-kid=\"22\">Email</span>\n      </button>\n    </nav>\n  </header>\n\n  <main class=\"relative z-10 pt-28 pb-12 px-6 max-w-7xl mx-auto space-y-12\" data-kid=\"23\">\n    \n    \n    <section id=\"view-dashboard\" class=\"space-y-8\" data-kid=\"24\">\n      <div class=\"flex items-center justify-between\" data-kid=\"25\">\n        <div data-kid=\"26\">\n          <h1 class=\"text-4xl tracking-tight\" data-kid=\"27\">Telemetry Console</h1>\n          <p class=\"text-white/50 text-sm mt-1\" data-kid=\"28\">Real-time tracking of utility automation nodes</p>\n        </div>\n        <button class=\"px-6 py-2 bg-white/5 border border-white/10 rounded-full text-sm font-medium hover:bg-white/10 transition-colors\" data-kid=\"29\">\n          <i class=\"ti ti-refresh mr-2\" data-kid=\"30\"></i>Sync Data\n        </button>\n      </div>\n\n      \n      <div class=\"grid grid-cols-1 md:grid-cols-4 gap-6\" data-kid=\"31\">\n        <div class=\"glass-card p-6 relative overflow-hidden group\" data-kid=\"32\">\n          <div class=\"absolute -right-4 -bottom-4 opacity-5 group-hover:opacity-10 transition-opacity\" data-kid=\"33\">\n            <i class=\"ti ti-link text-8xl\" data-kid=\"34\"></i>\n          </div>\n          <span class=\"text-xs font-semibold text-[#00FFBF] uppercase tracking-wider\" data-kid=\"35\">Total Links</span>\n          <div class=\"text-4xl mt-2\" data-kid=\"36\">12,482</div>\n          <div class=\"mt-2 text-xs text-white/40 flex items-center gap-1\" data-kid=\"37\">\n            <i class=\"ti ti-trending-up text-green-400\" data-kid=\"38\"></i> <span class=\"text-green-400\" data-kid=\"39\">+12%</span> from last session\n          </div>\n        </div>\n        <div class=\"glass-card p-6 relative overflow-hidden group\" data-kid=\"40\">\n          <div class=\"absolute -right-4 -bottom-4 opacity-5 group-hover:opacity-10 transition-opacity\" data-kid=\"41\">\n            <i class=\"ti ti-circle-check text-8xl\" data-kid=\"42\"></i>\n          </div>\n          <span class=\"text-xs font-semibold text-[#00FFBF] uppercase tracking-wider\" data-kid=\"43\">Validated</span>\n          <div class=\"text-4xl mt-2\" data-kid=\"44\">11,902</div>\n          <div class=\"mt-2 text-xs text-white/40\" data-kid=\"45\">95.3% Success Rate</div>\n        </div>\n        <div class=\"glass-card p-6 relative overflow-hidden group\" data-kid=\"46\">\n          <div class=\"absolute -right-4 -bottom-4 opacity-5 group-hover:opacity-10 transition-opacity\" data-kid=\"47\">\n            <i class=\"ti ti-video text-8xl\" data-kid=\"48\"></i>\n          </div>\n          <span class=\"text-xs font-semibold text-[#00FFBF] uppercase tracking-wider\" data-kid=\"49\">Downloaded</span>\n          <div class=\"text-4xl mt-2\" data-kid=\"50\">8,241</div>\n          <div class=\"mt-2 text-xs text-white/40 flex items-center gap-1\" data-kid=\"51\">\n            <i class=\"ti ti-cloud-download text-cyan-400\" data-kid=\"52\"></i> 4.2 GB processed today\n          </div>\n        </div>\n        <div class=\"glass-card p-6 relative overflow-hidden group\" data-kid=\"53\">\n          <div class=\"absolute -right-4 -bottom-4 opacity-5 group-hover:opacity-10 transition-opacity\" data-kid=\"54\">\n            <i class=\"ti ti-mail text-8xl\" data-kid=\"55\"></i>\n          </div>\n          <span class=\"text-xs font-semibold text-[#00FFBF] uppercase tracking-wider\" data-kid=\"56\">Emails</span>\n          <div class=\"text-4xl mt-2\" data-kid=\"57\">24,109</div>\n          <div class=\"mt-2 text-xs text-white/40\" data-kid=\"58\">Aggregated from 142 sheets</div>\n        </div>\n      </div>\n\n      \n      <div class=\"grid grid-cols-1 lg:grid-cols-3 gap-8\" data-kid=\"59\">\n        <div class=\"glass-card p-8 lg:col-span-2\" data-kid=\"60\">\n          <div class=\"flex items-center justify-between mb-8\" data-kid=\"61\">\n            <h3 class=\"text-xl\" data-kid=\"62\">Extraction Velocity</h3>\n            <div class=\"flex gap-2\" data-kid=\"63\">\n              <span class=\"px-3 py-1 bg-white/5 rounded-full text-[10px] border border-white/10 uppercase font-bold text-white/40\" data-kid=\"64\">YouTube</span>\n              <span class=\"px-3 py-1 bg-white/5 rounded-full text-[10px] border border-white/10 uppercase font-bold text-white/40\" data-kid=\"65\">TikTok</span>\n            </div>\n          </div>\n          <div class=\"h-[300px] w-full bg-white/5 rounded-2xl flex items-end p-4 gap-2\" data-kid=\"66\">\n            \n            <div class=\"flex-1 bg-white/10 rounded-t-lg h-[60%] hover:bg-[#00FFBF]/20 transition-all cursor-pointer\" data-kid=\"67\"></div>\n            <div class=\"flex-1 bg-white/10 rounded-t-lg h-[40%] hover:bg-[#00FFBF]/20 transition-all cursor-pointer\" data-kid=\"68\"></div>\n            <div class=\"flex-1 bg-white/10 rounded-t-lg h-[80%] hover:bg-[#00FFBF]/20 transition-all cursor-pointer\" data-kid=\"69\"></div>\n            <div class=\"flex-1 bg-white/10 rounded-t-lg h-[55%] hover:bg-[#00FFBF]/20 transition-all cursor-pointer\" data-kid=\"70\"></div>\n            <div class=\"flex-1 bg-[#00FFBF]/30 rounded-t-lg h-[90%] hover:bg-[#00FFBF]/40 transition-all cursor-pointer shadow-[0_0_15px_rgba(0,255,191,0.2)]\" data-kid=\"71\"></div>\n            <div class=\"flex-1 bg-white/10 rounded-t-lg h-[65%] hover:bg-[#00FFBF]/20 transition-all cursor-pointer\" data-kid=\"72\"></div>\n            <div class=\"flex-1 bg-white/10 rounded-t-lg h-[45%] hover:bg-[#00FFBF]/20 transition-all cursor-pointer\" data-kid=\"73\"></div>\n          </div>\n        </div>\n        <div class=\"glass-card p-8\" data-kid=\"74\">\n          <h3 class=\"text-xl mb-8\" data-kid=\"75\">System Health</h3>\n          <div class=\"flex flex-col items-center justify-center h-[300px]\" data-kid=\"76\">\n            \n            <div class=\"relative w-48 h-48\" data-kid=\"77\">\n              <svg viewBox=\"0 0 36 36\" class=\"w-full h-full\" data-kid=\"78\">\n                <circle class=\"progress-ring-bg\" stroke-width=\"3\" fill=\"transparent\" r=\"16\" cx=\"18\" cy=\"18\" data-kid=\"79\"></circle>\n                <circle class=\"progress-ring-fill\" stroke-width=\"3\" stroke-dasharray=\"100, 100\" fill=\"transparent\" r=\"16\" cx=\"18\" cy=\"18\" style=\"stroke-dasharray: 85, 100;\" data-kid=\"80\"></circle>\n              </svg>\n              <div class=\"absolute inset-0 flex flex-col items-center justify-center\" data-kid=\"81\">\n                <span class=\"text-4xl font-bold\" data-kid=\"82\">85%</span>\n                <span class=\"text-[10px] text-white/40 uppercase font-bold\" data-kid=\"83\">Efficiency</span>\n              </div>\n            </div>\n            <div class=\"mt-8 space-y-3 w-full\" data-kid=\"84\">\n              <div class=\"flex items-center justify-between text-xs\" data-kid=\"85\">\n                <span class=\"flex items-center gap-2\" data-kid=\"86\"><div class=\"w-2 h-2 rounded-full bg-[#00FFBF]\" data-kid=\"87\"></div> Validated</span>\n                <span class=\"font-bold\" data-kid=\"88\">11,902</span>\n              </div>\n              <div class=\"flex items-center justify-between text-xs\" data-kid=\"89\">\n                <span class=\"flex items-center gap-2\" data-kid=\"90\"><div class=\"w-2 h-2 rounded-full bg-white/20\" data-kid=\"91\"></div> Pending</span>\n                <span class=\"font-bold\" data-kid=\"92\">580</span>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    \n    <section id=\"view-downloader\" class=\"space-y-8 hidden\" data-kid=\"93\">\n      <div class=\"grid grid-cols-1 lg:grid-cols-12 gap-8\" data-kid=\"94\">\n        \n        <div class=\"lg:col-span-4 space-y-6\" data-kid=\"95\">\n          <div class=\"glass-card p-8 border-dashed border-white/30 hover:border-[#00FFBF]/50 transition-all cursor-pointer group\" data-kid=\"96\">\n            <div class=\"flex flex-col items-center justify-center py-12 text-center\" data-kid=\"97\">\n              <div class=\"w-16 h-16 bg-white/5 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 group-hover:bg-[#00FFBF]/10 transition-all\" data-kid=\"98\">\n                <i class=\"ti ti-cloud-upload text-3xl text-[#00FFBF]\" data-kid=\"99\"></i>\n              </div>\n              <h3 class=\"text-xl mb-2\" data-kid=\"100\">Sync Spreadsheet</h3>\n              <p class=\"text-white/40 text-sm\" data-kid=\"101\">Drop your Excel file here to parse YouTube or TikTok channels</p>\n              <input type=\"file\" class=\"hidden\" data-kid=\"102\">\n            </div>\n          </div>\n\n          <div class=\"glass-card p-6\" data-kid=\"103\">\n            <h4 class=\"text-sm font-bold uppercase tracking-widest text-[#00FFBF] mb-4\" data-kid=\"104\">Direct Inspector</h4>\n            <div class=\"relative\" data-kid=\"105\">\n              <input type=\"text\" placeholder=\"https://youtube.com/watch?v=...\" class=\"w-full bg-black/20 border border-white/10 rounded-xl px-4 py-4 text-sm focus:outline-none focus:border-[#00FFBF]/50 transition-all pr-12\" data-kid=\"106\">\n              <button class=\"absolute right-2 top-2 w-10 h-10 bg-[#00FFBF] text-[#1E2952] rounded-lg flex items-center justify-center shadow-lg active:scale-95 transition-transform\" data-kid=\"107\">\n                <i class=\"ti ti-arrow-right font-bold\" data-kid=\"108\"></i>\n              </button>\n            </div>\n          </div>\n        </div>\n\n        \n        <div class=\"lg:col-span-8 glass-card p-8\" data-kid=\"109\">\n          <div class=\"flex items-center justify-between mb-8\" data-kid=\"110\">\n            <h3 class=\"text-xl\" data-kid=\"111\">Scraped Media Artifacts</h3>\n            <div class=\"flex gap-2\" data-kid=\"112\">\n              <button class=\"px-4 py-2 bg-[#00FFBF] text-[#1E2952] text-xs font-bold rounded-full shadow-lg active:scale-95 transition-transform\" data-kid=\"113\">Download All</button>\n              <button class=\"px-4 py-2 bg-white/5 border border-white/10 text-xs font-bold rounded-full hover:bg-white/10 transition-all\" data-kid=\"114\">Filter</button>\n            </div>\n          </div>\n          \n          <div class=\"pinterest-grid gap-4\" data-kid=\"115\">\n            \n            <div class=\"glass-card overflow-hidden group relative\" style=\"grid-row-end: span 12;\" data-kid=\"116\">\n              <img src=\"https://images.unsplash.com/photo-1653481351422-91ceed9c94bd?auto=format&w=600&q=80&fit=crop\" class=\"w-full h-full object-cover group-hover:scale-110 transition-transform duration-500\" loading=\"lazy\" decoding=\"async\" data-kid=\"117\">\n              <div class=\"absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity p-4 flex flex-col justify-end\" data-kid=\"118\">\n                <h4 class=\"text-xs font-bold\" data-kid=\"119\">Midnight Coding Sessions</h4>\n                <p class=\"text-[10px] text-white/60\" data-kid=\"120\">Duration: 12:42</p>\n              </div>\n            </div>\n            <div class=\"glass-card overflow-hidden group relative\" style=\"grid-row-end: span 18;\" data-kid=\"121\">\n              <img src=\"https://images.unsplash.com/photo-1672080070762-764c74ee1227?auto=format&w=600&q=80&fit=crop\" class=\"w-full h-full object-cover group-hover:scale-110 transition-transform duration-500\" loading=\"lazy\" decoding=\"async\" data-kid=\"122\">\n              <div class=\"absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity p-4 flex flex-col justify-end\" data-kid=\"123\">\n                <h4 class=\"text-xs font-bold\" data-kid=\"124\">Fluid UI Design Theory</h4>\n                <p class=\"text-[10px] text-white/60\" data-kid=\"125\">Duration: 08:15</p>\n              </div>\n            </div>\n            <div class=\"glass-card overflow-hidden group relative\" style=\"grid-row-end: span 14;\" data-kid=\"126\">\n              <img src=\"https://images.unsplash.com/photo-1679669693872-12d991fc9d93?auto=format&w=600&q=80&fit=crop\" class=\"w-full h-full object-cover group-hover:scale-110 transition-transform duration-500\" loading=\"lazy\" decoding=\"async\" data-kid=\"127\">\n              <div class=\"absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity p-4 flex flex-col justify-end\" data-kid=\"128\">\n                <h4 class=\"text-xs font-bold\" data-kid=\"129\">Spatial Computing Trends</h4>\n                <p class=\"text-[10px] text-white/60\" data-kid=\"130\">Duration: 24:00</p>\n              </div>\n            </div>\n            <div class=\"glass-card overflow-hidden group relative\" style=\"grid-row-end: span 16;\" data-kid=\"131\">\n              <img src=\"https://images.unsplash.com/photo-1672080070747-9b28b4b403af?auto=format&w=600&q=80&fit=crop\" class=\"w-full h-full object-cover group-hover:scale-110 transition-transform duration-500\" loading=\"lazy\" decoding=\"async\" data-kid=\"132\">\n              <div class=\"absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity p-4 flex flex-col justify-end\" data-kid=\"133\">\n                <h4 class=\"text-xs font-bold\" data-kid=\"134\">Mesh Gradient Tutorial</h4>\n                <p class=\"text-[10px] text-white/60\" data-kid=\"135\">Duration: 15:33</p>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    \n    <section id=\"view-automation\" class=\"space-y-8 hidden\" data-kid=\"136\">\n      <div class=\"flex items-center justify-between\" data-kid=\"137\">\n        <div data-kid=\"138\">\n          <h1 class=\"text-4xl tracking-tight\" data-kid=\"139\">Automation Engine</h1>\n          <p class=\"text-white/50 text-sm mt-1\" data-kid=\"140\">Hidemium & Playwright script orchestration</p>\n        </div>\n        <button class=\"px-8 py-3 bg-[#00FFBF] text-[#1E2952] rounded-full font-bold shadow-[0_0_30px_rgba(0,255,191,0.3)] hover:scale-105 active:scale-95 transition-all\" data-kid=\"141\">\n          <i class=\"ti ti-player-play-filled mr-2\" data-kid=\"142\"></i>Initiate Bulk Creation\n        </button>\n      </div>\n\n      <div class=\"grid grid-cols-1 lg:grid-cols-2 gap-8\" data-kid=\"143\">\n        <div class=\"glass-card p-8\" data-kid=\"144\">\n          <h3 class=\"text-xl mb-6\" data-kid=\"145\">Execution Log</h3>\n          <div class=\"space-y-6 relative before:absolute before:left-[11px] before:top-2 before:bottom-2 before:w-[2px] before:bg-white/10\" data-kid=\"146\">\n            \n            <div class=\"relative pl-10\" data-kid=\"147\">\n              <div class=\"absolute left-0 top-1 w-6 h-6 rounded-full bg-[#00FFBF] border-4 border-[#1E2952] shadow-[0_0_10px_rgba(0,255,191,0.5)]\" data-kid=\"148\"></div>\n              <h4 class=\"text-sm font-bold\" data-kid=\"149\">Gmail Account #241 created</h4>\n              <p class=\"text-xs text-white/40 mt-1\" data-kid=\"150\">Profile: Hidemium_G241 | Status: SUCCESS</p>\n              <span class=\"text-[10px] text-white/20 absolute right-0 top-1\" data-kid=\"151\">12:04:12</span>\n            </div>\n            <div class=\"relative pl-10\" data-kid=\"152\">\n              <div class=\"absolute left-0 top-1 w-6 h-6 rounded-full bg-[#00FFBF] border-4 border-[#1E2952]\" data-kid=\"153\"></div>\n              <h4 class=\"text-sm font-bold\" data-kid=\"154\">Email extraction complete</h4>\n              <p class=\"text-xs text-white/40 mt-1\" data-kid=\"155\">Source: data_input_v2.xlsx | 1,402 items</p>\n              <span class=\"text-[10px] text-white/20 absolute right-0 top-1\" data-kid=\"156\">11:58:45</span>\n            </div>\n            <div class=\"relative pl-10 opacity-50\" data-kid=\"157\">\n              <div class=\"absolute left-0 top-1 w-6 h-6 rounded-full bg-white/20 border-4 border-[#1E2952]\" data-kid=\"158\"></div>\n              <h4 class=\"text-sm font-bold\" data-kid=\"159\">Profile Warm-up initiated</h4>\n              <p class=\"text-xs text-white/40 mt-1\" data-kid=\"160\">Running Hidemium manager... [32/100]</p>\n              <span class=\"text-[10px] text-white/20 absolute right-0 top-1\" data-kid=\"161\">11:50:22</span>\n            </div>\n          </div>\n        </div>\n\n        <div class=\"glass-card p-8 bg-black/40 border-white/5\" data-kid=\"162\">\n          <div class=\"flex items-center gap-3 mb-6\" data-kid=\"163\">\n            <div class=\"w-3 h-3 rounded-full bg-red-500\" data-kid=\"164\"></div>\n            <div class=\"w-3 h-3 rounded-full bg-amber-500\" data-kid=\"165\"></div>\n            <div class=\"w-3 h-3 rounded-full bg-green-500\" data-kid=\"166\"></div>\n            <span class=\"text-xs text-white/40 font-mono ml-2\" data-kid=\"167\">hidemium_manager --verbose</span>\n          </div>\n          <div class=\"font-mono text-sm space-y-2 text-[#00FFBF]/80 overflow-y-auto max-h-[300px]\" data-kid=\"168\">\n            <p data-kid=\"169\">> initializing playwright engine...</p>\n            <p data-kid=\"170\">> connecting to hidemium local api on port 3001</p>\n            <p data-kid=\"171\">> found 14 active profiles</p>\n            <p data-kid=\"172\">> starting automation script: gmail_v4_creator.js</p>\n            <p class=\"text-white/80\" data-kid=\"173\">> [12:04:12] Profile: Hidemium_G241 -> Account Verified</p>\n            <p data-kid=\"174\">> waiting for cooldown (120s)...</p>\n            <p class=\"animate-pulse\" data-kid=\"175\">_</p>\n          </div>\n        </div>\n      </div>\n    </section>\n\n  </main>\n\n  \n  <div class=\"fixed bottom-8 right-8 z-[100] flex flex-col gap-3 pointer-events-none\" data-kid=\"176\">\n    <div class=\"toast glass-card !rounded-2xl p-4 w-72 flex items-center gap-4 border-l-4 border-l-[#00FFBF] shadow-2xl\" data-kid=\"177\">\n      <div class=\"w-10 h-10 bg-[#00FFBF]/10 rounded-full flex items-center justify-center\" data-kid=\"178\">\n        <i class=\"ti ti-check text-[#00FFBF] text-xl\" data-kid=\"179\"></i>\n      </div>\n      <div data-kid=\"180\">\n        <h5 class=\"text-xs font-bold\" data-kid=\"181\">Automation Success</h5>\n        <p class=\"text-[10px] text-white/40\" data-kid=\"182\">Profile G241 initialized</p>\n      </div>\n    </div>\n    <div class=\"toast glass-card !rounded-2xl p-4 w-72 flex items-center gap-4 border-l-4 border-l-[#00FFBF] shadow-2xl opacity-70\" data-kid=\"183\">\n      <div class=\"w-10 h-10 bg-[#00FFBF]/10 rounded-full flex items-center justify-center\" data-kid=\"184\">\n        <i class=\"ti ti-loader text-[#00FFBF] text-xl animate-spin\" data-kid=\"185\"></i>\n      </div>\n      <div data-kid=\"186\">\n        <h5 class=\"text-xs font-bold\" data-kid=\"187\">Processing Batch</h5>\n        <p class=\"text-[10px] text-white/40\" data-kid=\"188\">Analyzing 1,402 links</p>\n      </div>\n    </div>\n  </div>\n\n  \n  <div id=\"modal-container\" class=\"fixed inset-0 z-[200] flex items-center justify-center bg-black/80 backdrop-blur-md hidden opacity-0\" data-kid=\"189\">\n    <div id=\"modal-content\" class=\"glass-card max-w-4xl w-[90%] p-2 overflow-hidden relative\" data-kid=\"190\">\n      <button class=\"absolute top-4 right-4 w-10 h-10 bg-white/10 rounded-full flex items-center justify-center text-white hover:bg-white/20 transition-all z-10\" data-kid=\"191\">\n        <i class=\"ti ti-x text-xl\" data-kid=\"192\"></i>\n      </button>\n      <div class=\"aspect-video bg-black rounded-2xl overflow-hidden\" data-kid=\"193\">\n        <video src=\"https://videos.pexels.com/video-files/7140928/7140928-sd_426_240_24fps.mp4\" poster=\"https://images.pexels.com/videos/7140928/pexels-photo-7140928.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=630&w=1200\" autoplay muted loop playsinline preload=\"metadata\" class=\"w-full h-full object-cover\" data-kid=\"194\"></video>\n      </div>\n      <div class=\"p-6\" data-kid=\"195\">\n        <h2 class=\"text-2xl mb-2\" data-kid=\"196\">Video Inspector Detail</h2>\n        <p class=\"text-white/40 text-sm\" data-kid=\"197\">Reviewing source media before finalizing download sequence.</p>\n      </div>\n    </div>\n  </div>\n</div>\n\n<script type=\"module\" data-kid=\"198\">\n  import { animate, spring, scroll, inView, hover } from \"https://cdn.jsdelivr.net/npm/motion@12/+esm\"\n\n  // Background Orbs Floating Motion\n  const orbs = document.querySelectorAll('.orb');\n  orbs.forEach((orb, i) => {\n    animate(orb, \n      { \n        x: [0, 100 * (i % 2 === 0 ? 1 : -1), 0],\n        y: [0, 150 * (i % 2 === 0 ? -1 : 1), 0],\n        scale: [1, 1.2, 1]\n      }, \n      { \n        duration: 15 + i * 2, \n        repeat: Infinity, \n        ease: \"easeInOut\" \n      }\n    );\n  });\n\n  // Navigation Logic\n  const navItems = document.querySelectorAll('.pill-nav-item');\n  const sections = {\n    dashboard: document.getElementById('view-dashboard'),\n    downloader: document.getElementById('view-downloader'),\n    automation: document.getElementById('view-automation'),\n    email: document.getElementById('view-automation') // Reuse automation view for demo\n  };\n\n  navItems.forEach(btn => {\n    btn.addEventListener('click', () => {\n      const view = btn.dataset.view;\n      \n      // Update UI\n      navItems.forEach(b => b.classList.remove('active'));\n      btn.classList.add('active');\n\n      // Switch Sections with animation\n      Object.keys(sections).forEach(key => {\n        const section = sections[key];\n        if (key === view) {\n          section.classList.remove('hidden');\n          animate(section, { opacity: [0, 1], y: [20, 0] }, { duration: 0.5 });\n        } else {\n          section.classList.add('hidden');\n        }\n      });\n    });\n  });\n\n  // Hover Glows (#motion-hover-glow)\n  const cards = document.querySelectorAll('.glass-card');\n  cards.forEach(card => {\n    hover(card, (element) => {\n      animate(element, { \n        scale: 1.02, \n        boxShadow: \"0 0 40px rgba(0, 255, 191, 0.2)\",\n        borderColor: \"rgba(0, 255, 191, 0.4)\"\n      }, { duration: 0.3 });\n      \n      return () => animate(element, { \n        scale: 1, \n        boxShadow: \"0 8px 32px 0 rgba(0,0,0,0.37)\",\n        borderColor: \"rgba(255, 255, 255, 0.2)\"\n      }, { duration: 0.3 });\n    });\n  });\n\n  // Entry Animations\n  inView(\".glass-card\", (info) => {\n    animate(info.target, { opacity: [0, 1], y: [40, 0] }, { \n      delay: 0.1,\n      duration: 0.6,\n      easing: spring({ stiffness: 100, damping: 20 })\n    });\n  });\n\n  // Modal Functionality (#motion-modal-fade-scale)\n  const modalContainer = document.getElementById('modal-container');\n  const modalContent = document.getElementById('modal-content');\n  const closeBtn = modalContainer.querySelector('button');\n  const galleryItems = document.querySelectorAll('.pinterest-grid > div');\n\n  function openModal() {\n    modalContainer.classList.remove('hidden');\n    animate(modalContainer, { opacity: [0, 1] }, { duration: 0.3 });\n    animate(modalContent, { scale: [0.8, 1], opacity: [0, 1] }, { \n      duration: 0.4, \n      easing: spring({ stiffness: 200, damping: 15 }) \n    });\n  }\n\n  function closeModal() {\n    animate(modalContent, { scale: 0.8, opacity: 0 }, { duration: 0.3 });\n    animate(modalContainer, { opacity: 0 }, { duration: 0.3 }).finished.then(() => {\n      modalContainer.classList.add('hidden');\n    });\n  }\n\n  galleryItems.forEach(item => item.addEventListener('click', openModal));\n  closeBtn.addEventListener('click', closeModal);\n  modalContainer.addEventListener('click', (e) => {\n    if (e.target === modalContainer) closeModal();\n  });\n\n  // Progress Ring Animation (#motion-progress-ring)\n  const circle = document.querySelector('.progress-ring-fill');\n  if (circle) {\n    animate(circle, { strokeDasharray: [\"0, 100\", \"85, 100\"] }, { duration: 2, ease: \"easeOut\" });\n  }\n\n  // Toast Stack Entry\n  const toasts = document.querySelectorAll('.toast');\n  toasts.forEach((toast, i) => {\n    animate(toast, { x: [100, 0], opacity: [0, 1] }, { delay: 0.5 + i * 0.2, duration: 0.8, easing: spring() });\n  });\n\n</script>",
