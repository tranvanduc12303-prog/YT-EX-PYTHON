      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Anton&family=Inter:wght@400;700&family=JetBrains+Mono&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css');\n\n  body {\n    background-color: #2A3439;\n    color: #FFFFFF;\n    font-family: 'Inter', sans-serif;\n    margin: 0;\n    overflow-x: hidden;\n  }\n\n  .font-anton { font-family: 'Anton', sans-serif; }\n  .font-mono { font-family: 'JetBrains Mono', monospace; }\n\n  .brutalist-border { border: 3px solid #000; }\n  .brutalist-shadow { shadow: 4px 4px 0 #000; }\n  \n  .tab-active {\n    background-color: #FDEE00;\n    color: #000;\n  }\n\n  .ledger-row {\n    border-bottom: 1px solid #708090;\n    padding: 24px 0;\n  }\n\n  .ticker-container::-webkit-scrollbar { width: 6px; }\n  .ticker-container::-webkit-scrollbar-thumb { background: #708090; }\n\n  /* Grid helper */\n  .grid-cols-custom { grid-template-columns: 1.2fr 1fr; }\n</style>\n\n<div class=\"min-h-screen flex flex-col\" data-kid=\"1\">\n  \n  <nav class=\"sticky top-0 z-50 bg-[#2A3439] border-b-[3px] border-black\" data-kid=\"2\">\n    <div class=\"flex items-center h-20\" data-kid=\"3\">\n      <div class=\"px-8 border-r-[3px] border-black h-full flex items-center bg-[#FDEE00]\" data-kid=\"4\">\n        <span class=\"font-anton text-2xl text-black tracking-tighter uppercase\" data-kid=\"5\">EXCEL UTILS PRO</span>\n      </div>\n      <div class=\"flex h-full flex-1\" data-kid=\"6\">\n        <button onclick=\"switchView('dashboard')\" class=\"nav-tab px-10 font-anton text-lg uppercase border-r-[3px] border-black hover:bg-[#FDEE00]/10 transition-none tab-active\" data-kid=\"7\">Dashboard</button>\n        <button onclick=\"switchView('excel')\" class=\"nav-tab px-10 font-anton text-lg uppercase border-r-[3px] border-black hover:bg-[#FDEE00]/10 transition-none\" data-kid=\"8\">Excel Batch</button>\n        <button onclick=\"switchView('direct')\" class=\"nav-tab px-10 font-anton text-lg uppercase border-r-[3px] border-black hover:bg-[#FDEE00]/10 transition-none\" data-kid=\"9\">URL Fetch</button>\n        <button onclick=\"switchView('gmail')\" class=\"nav-tab px-10 font-anton text-lg uppercase border-r-[3px] border-black hover:bg-[#FDEE00]/10 transition-none\" data-kid=\"10\">Automation</button>\n      </div>\n      <div class=\"px-8 flex items-center gap-4\" data-kid=\"11\">\n        <span class=\"font-mono text-xs text-[#708090] uppercase\" data-kid=\"12\">System: Online</span>\n        <div class=\"w-3 h-3 bg-[#FDEE00] rounded-full animate-pulse shadow-[0_0_10px_#FDEE00]\" data-kid=\"13\"></div>\n      </div>\n    </div>\n  </nav>\n\n  <main class=\"flex-1 p-12\" data-kid=\"14\">\n    \n    <div class=\"mb-12 overflow-hidden\" data-kid=\"15\">\n      <h1 id=\"view-title\" class=\"font-anton text-[12vw] leading-none uppercase text-[#708090]/10 whitespace-nowrap select-none\" data-kid=\"16\">DASHBOARD</h1>\n    </div>\n\n    \n    <section id=\"view-dashboard\" class=\"view-content block\" data-kid=\"17\">\n      <div class=\"max-w-6xl mx-auto\" data-kid=\"18\">\n        <div class=\"grid grid-cols-1 gap-0\" data-kid=\"19\">\n          <div class=\"ledger-row flex items-end justify-between stagger-item\" data-kid=\"20\">\n            <div data-kid=\"21\">\n              <span class=\"text-[#708090] uppercase font-bold text-sm tracking-widest\" data-kid=\"22\">Youtube Pipeline</span>\n              <p class=\"text-xl mt-2\" data-kid=\"23\">Total links processed via excel</p>\n            </div>\n            <span class=\"font-anton text-8xl text-[#FDEE00] leading-none\" data-kid=\"24\">1,284</span>\n          </div>\n          <div class=\"ledger-row flex items-end justify-between stagger-item\" data-kid=\"25\">\n            <div data-kid=\"26\">\n              <span class=\"text-[#708090] uppercase font-bold text-sm tracking-widest\" data-kid=\"27\">Validation Rate</span>\n              <p class=\"text-xl mt-2\" data-kid=\"28\">Verified media integrity status</p>\n            </div>\n            <span class=\"font-anton text-8xl text-[#FDEE00] leading-none\" data-kid=\"29\">94.2%</span>\n          </div>\n          <div class=\"ledger-row flex items-end justify-between stagger-item\" data-kid=\"30\">\n            <div data-kid=\"31\">\n              <span class=\"text-[#708090] uppercase font-bold text-sm tracking-widest\" data-kid=\"32\">Automation Engine</span>\n              <p class=\"text-xl mt-2\" data-kid=\"33\">Gmail accounts generated total</p>\n            </div>\n            <span class=\"font-anton text-8xl text-[#FDEE00] leading-none\" data-kid=\"34\">432</span>\n          </div>\n          <div class=\"ledger-row flex items-end justify-between stagger-item\" data-kid=\"35\">\n            <div data-kid=\"36\">\n              <span class=\"text-[#708090] uppercase font-bold text-sm tracking-widest\" data-kid=\"37\">Data Extraction</span>\n              <p class=\"text-xl mt-2\" data-kid=\"38\">Leads captured from sheet sources</p>\n            </div>\n            <span class=\"font-anton text-8xl text-[#FDEE00] leading-none\" data-kid=\"39\">8.5K</span>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    \n    <section id=\"view-excel\" class=\"view-content hidden\" data-kid=\"40\">\n      <div class=\"grid grid-cols-1 lg:grid-cols-custom gap-12\" data-kid=\"41\">\n        <div class=\"bg-black/20 brutalist-border p-12 flex flex-col items-center justify-center min-h-[400px] hover:bg-black/40 transition-none cursor-pointer group shadow-[8px_8px_0_#000]\" data-kid=\"42\">\n          <div class=\"w-24 h-24 brutalist-border bg-[#FDEE00] flex items-center justify-center mb-6 group-hover:scale-110 transition-transform\" data-kid=\"43\">\n            <i class=\"ti ti-upload text-4xl text-black\" data-kid=\"44\"></i>\n          </div>\n          <h2 class=\"font-anton text-4xl uppercase mb-2\" data-kid=\"45\">Drop Excel Here</h2>\n          <p class=\"text-[#708090] font-mono\" data-kid=\"46\">SUPPORTED: .XLSX / .XLSM</p>\n        </div>\n        \n        <div class=\"flex flex-col\" data-kid=\"47\">\n          <div class=\"bg-[#FDEE00] text-black p-4 brutalist-border font-anton text-xl uppercase mb-4 shadow-[4px_4px_0_#000]\" data-kid=\"48\">\n            Detected Channels (12)\n          </div>\n          <div class=\"overflow-x-auto brutalist-border bg-black/20\" data-kid=\"49\">\n            <table class=\"w-full text-left font-mono text-sm\" data-kid=\"50\">\n              <thead data-kid=\"51\">\n                <tr class=\"bg-black border-b-[3px] border-black\" data-kid=\"52\">\n                  <th class=\"p-4 text-[#FDEE00]\" data-kid=\"53\">ID</th>\n                  <th class=\"p-4 text-[#FDEE00]\" data-kid=\"54\">CHANNEL_NAME</th>\n                  <th class=\"p-4 text-[#FDEE00]\" data-kid=\"55\">ACTION</th>\n                </tr>\n              </thead>\n              <tbody data-kid=\"56\">\n                <tr class=\"border-b border-[#708090]/30 hover:bg-[#FDEE00]/5\" data-kid=\"57\">\n                  <td class=\"p-4\" data-kid=\"58\">#001</td>\n                  <td class=\"p-4\" data-kid=\"59\">TechReviews Daily</td>\n                  <td class=\"p-4\" data-kid=\"60\"><button class=\"bg-[#FDEE00] text-black px-4 py-1 font-anton uppercase text-xs\" data-kid=\"61\">Fetch</button></td>\n                </tr>\n                <tr class=\"border-b border-[#708090]/30 hover:bg-[#FDEE00]/5\" data-kid=\"62\">\n                  <td class=\"p-4\" data-kid=\"63\">#002</td>\n                  <td class=\"p-4\" data-kid=\"64\">Cooking With Fire</td>\n                  <td class=\"p-4\" data-kid=\"65\"><button class=\"bg-[#FDEE00] text-black px-4 py-1 font-anton uppercase text-xs\" data-kid=\"66\">Fetch</button></td>\n                </tr>\n                <tr class=\"border-b border-[#708090]/30 hover:bg-[#FDEE00]/5\" data-kid=\"67\">\n                  <td class=\"p-4\" data-kid=\"68\">#003</td>\n                  <td class=\"p-4\" data-kid=\"69\">Global News 24/7</td>\n                  <td class=\"p-4\" data-kid=\"70\"><button class=\"bg-[#FDEE00] text-black px-4 py-1 font-anton uppercase text-xs\" data-kid=\"71\">Fetch</button></td>\n                </tr>\n              </tbody>\n            </table>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    \n    <section id=\"view-direct\" class=\"view-content hidden\" data-kid=\"72\">\n      <div class=\"max-w-5xl mx-auto\" data-kid=\"73\">\n        <label class=\"font-anton text-2xl uppercase text-[#FDEE00] mb-4 block\" data-kid=\"74\">Input Media URL</label>\n        <div class=\"flex gap-0 brutalist-border shadow-[12px_12px_0_#000] mb-12\" data-kid=\"75\">\n          <input type=\"text\" placeholder=\"HTTPS://YOUTUBE.COM/WATCH?V=...\" class=\"flex-1 bg-black p-8 font-anton text-3xl uppercase outline-none text-[#FDEE00] placeholder:text-[#708090]/30\" data-kid=\"76\">\n          <button class=\"bg-[#FDEE00] text-black px-12 font-anton text-2xl uppercase hover:invert transition-none\" data-kid=\"77\">Fetch</button>\n        </div>\n\n        <div class=\"grid grid-cols-2 gap-0 brutalist-border bg-black shadow-[8px_8px_0_#FDEE00]\" data-kid=\"78\">\n          <div class=\"p-10 border-r-[3px] border-[#708090]\" data-kid=\"79\">\n            <span class=\"text-[#708090] uppercase font-bold text-xs\" data-kid=\"80\">Metadata</span>\n            <h3 class=\"font-anton text-4xl mt-4 mb-6 uppercase\" data-kid=\"81\">Modern Architecture Documentary</h3>\n            <div class=\"space-y-4 font-mono\" data-kid=\"82\">\n              <div class=\"flex justify-between border-b border-[#708090]/30 pb-2\" data-kid=\"83\">\n                <span data-kid=\"84\">DURATION:</span>\n                <span class=\"text-[#FDEE00]\" data-kid=\"85\">12:44</span>\n              </div>\n              <div class=\"flex justify-between border-b border-[#708090]/30 pb-2\" data-kid=\"86\">\n                <span data-kid=\"87\">QUALITY:</span>\n                <span class=\"text-[#FDEE00]\" data-kid=\"88\">4K / 60FPS</span>\n              </div>\n            </div>\n          </div>\n          <div class=\"p-10 flex flex-col justify-center gap-4\" data-kid=\"89\">\n            <button class=\"bg-[#FDEE00] text-black p-6 font-anton text-2xl uppercase flex items-center justify-between hover:scale-[1.02] transition-transform\" data-kid=\"90\">\n              <span data-kid=\"91\">Download MP4</span>\n              <i class=\"ti ti-video text-3xl\" data-kid=\"92\"></i>\n            </button>\n            <button class=\"bg-transparent text-[#FDEE00] border-[3px] border-[#FDEE00] p-6 font-anton text-2xl uppercase flex items-center justify-between hover:bg-[#FDEE00] hover:text-black transition-colors\" data-kid=\"93\">\n              <span data-kid=\"94\">Download MP3</span>\n              <i class=\"ti ti-music text-3xl\" data-kid=\"95\"></i>\n            </button>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    \n    <section id=\"view-gmail\" class=\"view-content hidden\" data-kid=\"96\">\n      <div class=\"grid grid-cols-1 lg:grid-cols-3 gap-12\" data-kid=\"97\">\n        <div class=\"lg:col-span-1 space-y-8\" data-kid=\"98\">\n          <div class=\"brutalist-border p-8 bg-black shadow-[6px_6px_0_#000]\" data-kid=\"99\">\n            <h3 class=\"font-anton text-2xl uppercase mb-6 text-[#FDEE00]\" data-kid=\"100\">Configuration</h3>\n            <div class=\"space-y-6\" data-kid=\"101\">\n              <div data-kid=\"102\">\n                <label class=\"block text-xs uppercase font-bold text-[#708090] mb-2\" data-kid=\"103\">Process Mode</label>\n                <select class=\"w-full bg-[#2A3439] border-[3px] border-black p-4 font-anton text-lg uppercase outline-none\" data-kid=\"104\">\n                  <option data-kid=\"105\">Sequential</option>\n                  <option data-kid=\"106\">Parallel (High Speed)</option>\n                </select>\n              </div>\n              <div data-kid=\"107\">\n                <label class=\"block text-xs uppercase font-bold text-[#708090] mb-2\" data-kid=\"108\">Instance Count</label>\n                <input type=\"number\" value=\"10\" class=\"w-full bg-[#2A3439] border-[3px] border-black p-4 font-anton text-lg outline-none\" data-kid=\"109\">\n              </div>\n              <button class=\"w-full bg-[#FDEE00] text-black p-6 font-anton text-2xl uppercase brutalist-border shadow-[4px_4px_0_#000] hover:translate-y-[-2px] hover:shadow-[6px_6px_0_#000] transition-all\" data-kid=\"110\">Execute Engine</button>\n            </div>\n          </div>\n        </div>\n\n        <div class=\"lg:col-span-2\" data-kid=\"111\">\n          <div class=\"bg-black brutalist-border h-[600px] flex flex-col shadow-[12px_12px_0_#000]\" data-kid=\"112\">\n            <div class=\"p-4 border-b-[3px] border-black flex items-center justify-between bg-[#111]\" data-kid=\"113\">\n              <div class=\"flex gap-2\" data-kid=\"114\">\n                <div class=\"w-3 h-3 rounded-full bg-red-500\" data-kid=\"115\"></div>\n                <div class=\"w-3 h-3 rounded-full bg-yellow-500\" data-kid=\"116\"></div>\n                <div class=\"w-3 h-3 rounded-full bg-green-500\" data-kid=\"117\"></div>\n              </div>\n              <span class=\"font-mono text-xs text-[#708090]\" data-kid=\"118\">HIDEMIUM_AUTOMATION.LOG</span>\n            </div>\n            <div class=\"ticker-container flex-1 p-8 font-mono text-sm overflow-y-auto space-y-2 bg-black\" data-kid=\"119\">\n              <div class=\"flex gap-4\" data-kid=\"120\">\n                <span class=\"text-[#708090]\" data-kid=\"121\">[07:14:02]</span>\n                <span class=\"text-green-500\" data-kid=\"122\">[SUCCESS]</span>\n                <span data-kid=\"123\">Proxy connection established: US_WEST_04</span>\n              </div>\n              <div class=\"flex gap-4\" data-kid=\"124\">\n                <span class=\"text-[#708090]\" data-kid=\"125\">[07:14:05]</span>\n                <span class=\"text-[#FDEE00]\" data-kid=\"126\">[SYSTEM]</span>\n                <span data-kid=\"127\">Initializing browser instance #001...</span>\n              </div>\n              <div class=\"flex gap-4\" data-kid=\"128\">\n                <span class=\"text-[#708090]\" data-kid=\"129\">[07:14:12]</span>\n                <span class=\"text-blue-500\" data-kid=\"130\">[INFO]</span>\n                <span data-kid=\"131\">Navigating to accounts.google.com</span>\n              </div>\n              <div class=\"flex gap-4\" data-kid=\"132\">\n                <span class=\"text-[#708090]\" data-kid=\"133\">[07:14:18]</span>\n                <span class=\"text-green-500\" data-kid=\"134\">[DONE]</span>\n                <span class=\"bg-[#FDEE00] text-black px-1 font-bold\" data-kid=\"135\">CREATED: workspace_admin_v2@gmail.com</span>\n              </div>\n              <div class=\"flex gap-4 animate-pulse\" data-kid=\"136\">\n                <span class=\"text-[#708090]\" data-kid=\"137\">[07:14:20]</span>\n                <span class=\"text-[#FDEE00]\" data-kid=\"138\">[ACTIVE]</span>\n                <span data-kid=\"139\">Filling verification form... <span class=\"bg-white text-black inline-block w-2 h-4 align-middle ml-2\" data-kid=\"140\"></span></span>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </section>\n  </main>\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"141\"></script>\n<script type=\"module\" data-kid=\"142\">\n  import { animate, stagger } from 'https://cdn.jsdelivr.net/npm/motion@12/+esm';\n  import { scrambleText } from 'https://cdn.jsdelivr.net/npm/animejs@4/+esm';\n\n  window.switchView = function(viewId) {\n    const tabs = document.querySelectorAll('.nav-tab');\n    const contents = document.querySelectorAll('.view-content');\n    const title = document.getElementById('view-title');\n\n    // Tab UI update\n    tabs.forEach(tab => {\n      tab.classList.remove('tab-active');\n      if (tab.innerText.toLowerCase().includes(viewId.replace('view-', ''))) {\n        tab.classList.add('tab-active');\n      }\n    });\n\n    // Scramble effect on Title\n    const newTitleText = viewId.toUpperCase();\n    animate(\"#view-title\", { innerHTML: scrambleText({ text: newTitleText, chars: 'uppercase', from: 'center' }) }, { duration: 0.6 });\n\n    // Switch content with stagger effect\n    contents.forEach(content => {\n      if (content.id === 'view-' + viewId) {\n        content.classList.remove('hidden');\n        content.classList.add('block');\n        \n        // Stagger cascade animation\n        animate('.stagger-item', { opacity: [0, 1], y: [30, 0] }, { \n          delay: stagger(0.1),\n          duration: 0.5,\n          ease: 'easeOut'\n        });\n      } else {\n        content.classList.add('hidden');\n        content.classList.remove('block');\n      }\n    });\n  };\n\n  // Initial Animation\n  window.addEventListener('load', () => {\n    animate('.stagger-item', { opacity: [0, 1], y: [30, 0] }, { \n      delay: stagger(0.1),\n      duration: 0.8,\n      ease: 'easeOut'\n    });\n  });\n</script>",
